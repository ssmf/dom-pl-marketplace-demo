# ==========================================
# POSTGRESQL SETTINGS (Internal Docker DB)
# ==========================================
# Make sure to change these to strong, random values in production!
POSTGRES_DB=medusa-store
POSTGRES_USER=postgres
POSTGRES_PASSWORD=super_secure_postgres_password

# The explicit connection string Medusa uses to connect to the database.
# Format: postgres://<POSTGRES_USER>:<POSTGRES_PASSWORD>@postgres:5432/<POSTGRES_DB>?sslmode=disable
DATABASE_URL=postgres://postgres:super_secure_postgres_password@postgres:5432/medusa-store?sslmode=disable

# REDIS SETTINGS
# Must point to the internal Redis container on port 6379
REDIS_URL=redis://redis:6379

# ==========================================
# MEDUSA BACKEND SETTINGS
# ==========================================
# Medusa Secrets (MUST be changed in production to long, random strings)
JWT_SECRET=super_secure_jwt_secret_change_me
COOKIE_SECRET=super_secure_cookie_secret_change_me

# Medusa CORS Configuration
# These should point to your actual production domain names
# e.g., https://mystore.com for STORE_CORS, https://admin.mystore.com for ADMIN_CORS
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:3000

# NUXT FRONTEND SETTINGS
NUXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_test_YOUR_PRODUCTION_KEY_HERE

# The public URL where the browser can reach the Medusa backend
# In production, this should be the public domain of your Medusa instance (e.g., https://api.mystore.com)
NUXT_PUBLIC_MEDUSA_BASE_URL=http://localhost:9000